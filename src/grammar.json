    "_block_delimiter": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "(?:={4,}|-{4,}|\\.{4,}|\\*{4,}|\\+{4,}|_{4,})"
      }
    },
    "_inline_formatting_marker": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "(?:\\*|_|`|#|\\+)"
      }
