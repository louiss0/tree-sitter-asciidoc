      }
    },
    "_text_formatting_italic_end": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "_"
      }
    },
    "_text_formatting_monospace_start": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "`"
      }
    },
    "_text_formatting_monospace_end": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "`"
      }
    },
    "_text_formatting_highlighted_start": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "#"
      }
    },
    "_text_formatting_highlighted_end": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
