{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "asciidoc",
  "rules": {
    "source_file": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "document_author_line"
            },
            {
              "type": "SYMBOL",
              "name": "document_revision_line"
            },
            {
              "type": "SYMBOL",
              "name": "document_attribute"
            },
            {
              "type": "SYMBOL",
              "name": "document_title"
            }
          ]
        }
      ]
    },
    "_semi_colon": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": ";"
      }
    },
    "document_title": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "PATTERN",
            "value": "=|#"
          }
        },
        {
          "type": "FIELD",
          "name": "title",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "REPEAT1",
                "content": {
                  "type": "PATTERN",
                  "value": "\\w+"
                }
              }
            ]
          }
        }
      ]
    },
    "document_author_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "authors",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "REPEAT",
                "content": {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "REPEAT1",
                      "content": {
                        "type": "PATTERN",
                        "value": "[A-Z][a-z\\.]+"
                      }
                    },
                    {
                      "type": "SYMBOL",
                      "name": "_semi_colon"
                    }
                  ]
                }
              },
              {
                "type": "REPEAT1",
                "content": {
                  "type": "PATTERN",
                  "value": "[A-Z][a-z\\.]+"
                }
              }
            ]
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "email",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": "<"
                  },
                  {
                    "type": "PATTERN",
                    "value": "[\\w \\.,]+@[\\w \\.,]+"
                  },
                  {
                    "type": "STRING",
                    "value": ">"
                  }
                ]
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "document_revision_line": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "FIELD",
              "name": "version",
              "content": {
                "type": "PATTERN",
                "value": "v?\\d+\\.\\d+"
              }
            },
            {
              "type": "TOKEN",
              "content": {
                "type": "STRING",
                "value": ","
              }
            },
            {
              "type": "FIELD",
              "name": "date",
              "content": {
                "type": "PATTERN",
                "value": "[ \\w\\-,]+"
              }
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "TOKEN",
                      "content": {
                        "type": "STRING",
                        "value": ":"
                      }
                    },
                    {
                      "type": "FIELD",
                      "name": "message",
                      "content": {
                        "type": "SEQ",
                        "members": [
                          {
                            "type": "REPEAT1",
                            "content": {
                              "type": "PATTERN",
                              "value": "[ \\-\\w]+"
                            }
                          },
                          {
                            "type": "PATTERN",
                            "value": "\\n"
                          }
                        ]
                      }
                    }
                  ]
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "FIELD",
              "name": "version",
              "content": {
                "type": "PATTERN",
                "value": "v?\\d+\\.\\d+"
              }
            },
            {
              "type": "TOKEN",
              "content": {
                "type": "STRING",
                "value": ":"
              }
            },
            {
              "type": "FIELD",
              "name": "message",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "REPEAT1",
                    "content": {
                      "type": "PATTERN",
                      "value": "[ \\-\\w]+"
                    }
                  },
                  {
                    "type": "PATTERN",
                    "value": "\\n"
                  }
                ]
              }
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "version",
          "content": {
            "type": "PATTERN",
            "value": "v?\\d+\\.\\d+"
          }
        }
      ]
    },
    "document_attribute": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "PATTERN",
            "value": ":[a-zA-Z0-9_\\-]+:"
          }
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "PATTERN",
            "value": "[^\\\\]+"
          }
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}