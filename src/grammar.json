{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "asciidoc",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "document_author_line"
          },
          {
            "type": "SYMBOL",
            "name": "document_revision_line"
          },
          {
            "type": "SYMBOL",
            "name": "document_attribute"
          },
          {
            "type": "SYMBOL",
            "name": "document_title"
          },
          {
            "type": "SYMBOL",
            "name": "admonition"
          },
          {
            "type": "SYMBOL",
            "name": "admonition_block"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          }
        ]
      }
    },
    "document_title": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "SYMBOL",
            "name": "_document_title_heading_marker"
          }
        },
        {
          "type": "FIELD",
          "name": "title",
          "content": {
            "type": "REPEAT1",
            "content": {
              "type": "SYMBOL",
              "name": "_document_title_text_content"
            }
          }
        }
      ]
    },
    "_document_title_heading_marker": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "=|#"
      }
    },
    "_document_title_text_content": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\\w+"
      }
    },
    "document_author_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "authors",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "REPEAT",
                "content": {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "SYMBOL",
                      "name": "_document_author_line_name"
                    },
                    {
                      "type": "REPEAT1",
                      "content": {
                        "type": "SEQ",
                        "members": [
                          {
                            "type": "SYMBOL",
                            "name": "_space"
                          },
                          {
                            "type": "SYMBOL",
                            "name": "_document_author_line_name"
                          }
                        ]
                      }
                    },
                    {
                      "type": "SYMBOL",
                      "name": "_document_author_line_semi_colon"
                    }
                  ]
                }
              },
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "_document_author_line_name"
                  },
                  {
                    "type": "REPEAT1",
                    "content": {
                      "type": "SEQ",
                      "members": [
                        {
                          "type": "SYMBOL",
                          "name": "_space"
                        },
                        {
                          "type": "SYMBOL",
                          "name": "_document_author_line_name"
                        }
                      ]
                    }
                  }
                ]
              }
            ]
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "email",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "_space"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "_document_author_line_email_start_marker"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "_document_author_line_email_address"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "_document_author_line_email_end_marker"
                  }
                ]
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "_document_author_line_semi_colon": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": ";"
      }
    },
    "_document_author_line_name": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[A-Z][a-z\\.]+"
      }
    },
    "_document_author_line_email_address": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[\\w\\.-]+@[\\w\\.-]+"
      }
    },
    "_document_author_line_email_start_marker": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "<"
      }
    },
    "_document_author_line_email_end_marker": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": ">"
      }
    },
    "document_revision_line": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "FIELD",
              "name": "version",
              "content": {
                "type": "SYMBOL",
                "name": "_document_revision_line_version_text"
              }
            },
            {
              "type": "SYMBOL",
              "name": "_document_revision_line_comma"
            },
            {
              "type": "FIELD",
              "name": "date",
              "content": {
                "type": "SYMBOL",
                "name": "_document_revision_line_date_text"
              }
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "SYMBOL",
                      "name": "_document_revision_line_colon"
                    },
                    {
                      "type": "FIELD",
                      "name": "message",
                      "content": {
                        "type": "SEQ",
                        "members": [
                          {
                            "type": "REPEAT1",
                            "content": {
                              "type": "SEQ",
                              "members": [
                                {
                                  "type": "SYMBOL",
                                  "name": "_word_chars_with_dash"
                                },
                                {
                                  "type": "REPEAT",
                                  "content": {
                                    "type": "SEQ",
                                    "members": [
                                      {
                                        "type": "SYMBOL",
                                        "name": "_space"
                                      },
                                      {
                                        "type": "SYMBOL",
                                        "name": "_word_chars_with_dash"
                                      }
                                    ]
                                  }
                                }
                              ]
                            }
                          },
                          {
                            "type": "SYMBOL",
                            "name": "_newline"
                          }
                        ]
                      }
                    }
                  ]
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "FIELD",
              "name": "version",
              "content": {
                "type": "SYMBOL",
                "name": "_document_revision_line_version_text"
              }
            },
            {
              "type": "SYMBOL",
              "name": "_document_revision_line_colon"
            },
            {
              "type": "FIELD",
              "name": "message",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "REPEAT1",
                    "content": {
                      "type": "SEQ",
                      "members": [
                        {
                          "type": "SYMBOL",
                          "name": "_word_chars_with_dash"
                        },
                        {
                          "type": "REPEAT",
                          "content": {
                            "type": "SEQ",
                            "members": [
                              {
                                "type": "SYMBOL",
                                "name": "_space"
                              },
                              {
                                "type": "SYMBOL",
                                "name": "_word_chars_with_dash"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "type": "SYMBOL",
                    "name": "_newline"
                  }
                ]
              }
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "version",
          "content": {
            "type": "SYMBOL",
            "name": "_document_revision_line_version_text"
          }
        }
      ]
    },
    "_word_chars_with_dash": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[\\-\\w]+"
      }
    },
    "_document_revision_line_date_text": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[ \\w\\-,]+"
      }
    },
    "_document_revision_line_version_text": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "v?\\d+\\.\\d+"
      }
    },
    "_document_revision_line_colon": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": ":"
      }
    },
    "_document_revision_line_comma": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": ","
      }
    },
    "document_attribute": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "_document_attribute_name_marker"
          }
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "_document_attribute_value_text"
          }
        }
      ]
    },
    "_document_attribute_name_marker": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": ":[a-zA-Z0-9_\\-]+:"
      }
    },
    "_document_attribute_value_text": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\\\\\n\\r]+"
      }
    },
    "text_formatting": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "bold_text"
        },
        {
          "type": "SYMBOL",
          "name": "italic_text"
        },
        {
          "type": "SYMBOL",
          "name": "monospace_text"
        },
        {
          "type": "SYMBOL",
          "name": "highlighted_text"
        },
        {
          "type": "SYMBOL",
          "name": "superscript_text"
        },
        {
          "type": "SYMBOL",
          "name": "subscript_text"
        }
      ]
    },
    "bold_text": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "start_marker",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_bold_start"
          }
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_bold_content"
          }
        },
        {
          "type": "FIELD",
          "name": "end_marker",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_bold_end"
          }
        }
      ]
    },
    "italic_text": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "start_marker",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_italic_start"
          }
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_italic_content"
          }
        },
        {
          "type": "FIELD",
          "name": "end_marker",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_italic_end"
          }
        }
      ]
    },
    "monospace_text": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "start_marker",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_monospace_start"
          }
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_monospace_content"
          }
        },
        {
          "type": "FIELD",
          "name": "end_marker",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_monospace_end"
          }
        }
      ]
    },
    "highlighted_text": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "start_marker",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_highlighted_start"
          }
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_highlighted_content"
          }
        },
        {
          "type": "FIELD",
          "name": "end_marker",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_highlighted_end"
          }
        }
      ]
    },
    "superscript_text": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "start_marker",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_superscript_start"
          }
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_superscript_content"
          }
        },
        {
          "type": "FIELD",
          "name": "end_marker",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_superscript_end"
          }
        }
      ]
    },
    "subscript_text": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "start_marker",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_subscript_start"
          }
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_subscript_content"
          }
        },
        {
          "type": "FIELD",
          "name": "end_marker",
          "content": {
            "type": "SYMBOL",
            "name": "_text_formatting_subscript_end"
          }
        }
      ]
    },
    "_text_formatting_bold_content": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^*\\n\\r]+"
      }
    },
    "_text_formatting_italic_content": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^_\\n\\r]+"
      }
    },
    "_text_formatting_monospace_content": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^`\\n\\r]+"
      }
    },
    "_text_formatting_highlighted_content": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^#\\n\\r]+"
      }
    },
    "_text_formatting_superscript_content": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^^\\n\\r]+"
      }
    },
    "_text_formatting_subscript_content": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^~\\n\\r]+"
      }
    },
    "_text_formatting_bold_start": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "*"
      }
    },
    "_text_formatting_bold_end": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "*"
      }
    },
    "_text_formatting_italic_start": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
