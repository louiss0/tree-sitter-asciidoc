    },
    "_text_formatting_superscript_start": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "^"
      }
    },
    "_text_formatting_superscript_end": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "^"
      }
    },
    "_text_formatting_subscript_start": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "~"
      }
    },
    "_text_formatting_subscript_end": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "~"
      }
    },
    "admonition": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "admonition_type"
        },
        {
          "type": "TOKEN",
          "content": {
            "type": "STRING",
            "value": ":"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_space"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "admonition_content"
        }
      ]
    },
    "admonition_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "attribute"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "block_title"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "delimiter"
        },
        {
          "type": "SYMBOL",
          "name": "admonition_content"
        },
        {
          "type": "SYMBOL",
          "name": "delimiter"
        }
      ]
    },
    "admonition_type": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "NOTE"
          },
          {
            "type": "STRING",
            "value": "TIP"
          },
          {
            "type": "STRING",
            "value": "IMPORTANT"
          },
          {
            "type": "STRING",
            "value": "WARNING"
          },
          {
            "type": "STRING",
            "value": "CAUTION"
          }
        ]
      }
    },
    "admonition_content": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\n]+"
      }
    },
    "attribute": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "admonition_type"
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "SEQ",
                      "members": [
                        {
                          "type": "STRING",
                          "value": ","
                        },
                        {
                          "type": "SYMBOL",
                          "name": "attribute_name"
                        },
                        {
                          "type": "STRING",
                          "value": "="
                        },
                        {
                          "type": "SYMBOL",
                          "name": "attribute_value"
                        }
                      ]
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "SEQ",
                      "members": [
                        {
                          "type": "STRING",
                          "value": "."
                        },
                        {
                          "type": "SYMBOL",
                          "name": "role_name"
                        }
                      ]
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                }
              ]
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "attribute_name"
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "SEQ",
                      "members": [
                        {
                          "type": "STRING",
                          "value": "="
                        },
                        {
                          "type": "SYMBOL",
                          "name": "attribute_value"
                        }
                      ]
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "attribute_name": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[a-zA-Z][a-zA-Z0-9_-]*"
      }
    },
    "attribute_value": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\]]+"
      }
    },
    "role_name": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[a-zA-Z][a-zA-Z0-9_-]*"
      }
    },
    "delimiter": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "={4,}"
      }
    },
    "block_title": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "."
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_text"
              },
              {
                "type": "SYMBOL",
                "name": "_space"
              }
            ]
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "paragraph": {
      "type": "SEQ",
      "members": [
        {
          "type": "REPEAT1",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "text_formatting"
              },
              {
                "type": "SYMBOL",
                "name": "_text"
              },
              {
                "type": "SYMBOL",
                "name": "_space"
              }
            ]
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "_text": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\n\\r\\[\\]\\*_`#^~\\s]+"
      }
    },
    "unordered_list": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "list_item"
      }
    },
    "ordered_list": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
