{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "asciidoc",
  "rules": {
    "source_file": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "document_title"
        }
      ]
    },
    "document_title": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "TOKEN",
            "content": {
              "type": "PATTERN",
              "value": "[\\=#]"
            }
          }
        },
        {
          "type": "PATTERN",
          "value": "\\s+"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "title",
              "content": {
                "type": "PATTERN",
                "value": "[\\w\\s]+"
              }
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "FIELD",
                  "name": "title",
                  "content": {
                    "type": "PATTERN",
                    "value": "[\\w\\s]+:"
                  }
                },
                {
                  "type": "FIELD",
                  "name": "subtitle",
                  "content": {
                    "type": "PATTERN",
                    "value": "[\\w\\s]+"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}