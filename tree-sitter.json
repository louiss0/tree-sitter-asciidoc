{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "asciidoc",
      "camelcase": "Asciidoc",
      "title": "Tree Sitter Asciidoc",
      "scope": "source.asciidoc",
      "file-types": [
        "asciidoc",
        "asc",
        "adoc"
      ],
      "injection-regex": "^asciidoc$",
      "class-name": "TreeSitterAsciidoc"
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "This is the Zed Compatiable Tree sitter parser for Asciidoc",
    "authors": [
      {
        "name": "Shelton Louis",
        "email": "louisshelton0@gmail.com",
        "url": "https://github.com/louiss0"
      }
    ],
    "links": {
      "repository": "https://github.com/louiss0/tree-sitter-asciidoc"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}